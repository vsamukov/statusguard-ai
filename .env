
# GLOBAL ROLE: Set to "HUB" to manage multiple sites, or "NODE" for a single status page
MODE=HUB

# --- SHARED CONFIGURATION ---
PORT=3000
JWT_SECRET=voximplant-enterprise-secret-2024

# --- NODE CONFIGURATION (Required if MODE=NODE) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voximplant_status
# The secret the HUB must provide to manage this NODE
ADMIN_SECRET=secret-node-1

# --- EMAIL CONFIGURATION (Node only) ---
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
SMTP_FROM=status@voximplant.com

# --- HUB CONFIGURATION (Required if MODE=HUB) ---
# Master login for the central support hub
ADMIN_USER=admin
ADMIN_PASS=password
# List of nodes to manage. Note: Wrapped in quotes to handle special characters in JSON.
DASHBOARDS='[{"id":"node-1","name":"Production NA","url":"http://localhost:3000","adminSecret":"secret-node-1","color":"#3B82F6"},{"id":"node-2","name":"Staging EU","url":"http://localhost:3001","adminSecret":"secret-node-2","color":"#10B981"}]'

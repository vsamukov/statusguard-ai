# .env.example
PORT=3000
MODE=NODE # or HUB
ADMIN_SECRET=your-admin-secret-for-node-mode
ADMIN_USER=admin-username-for-hub-mode
ADMIN_PASS=admin-password-for-hub-mode
DASHBOARDS=[] # JSON array of dashboard configs for HUB mode
JWT_SECRET=your-jwt-secret
API_KEY=your-gemini-api-key
DATABASE_URL=postgresql://user:password@host:port/database
NOC_EMAIL=noc@yourcompany.com
NOTIFY_THRESHOLD=2 # hours
